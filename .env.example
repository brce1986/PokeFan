# =============================================================================
# PokéFan — variáveis de ambiente
# =============================================================================
# Copie para `.env` na raiz e preencha. O `.env` está no .gitignore — nunca
# commite. Os scripts em scripts/ leem esse arquivo direto (sem dotenv).
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (Vite)
# -----------------------------------------------------------------------------
# ATENÇÃO: tudo com prefixo VITE_ é embutido no bundle e fica público.
# Use aqui APENAS a chave anon/publishable — nunca a service_role.
# Em produção, essas mesmas variáveis precisam estar no painel da Vercel.
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# SCRIPTS NODE (scripts/)
# -----------------------------------------------------------------------------
# Sem prefixo VITE_ — ficam apenas na sua máquina, fora do bundle.
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# SEGREDO. Ignora RLS e tem acesso total ao banco. Só na sua máquina.
# Se vazar, rotacione em: Supabase -> Settings -> API -> service_role -> Reset.
SUPABASE_SERVICE_ROLE_KEY=

# Chave da API pokemontcg.io, usada por scripts/generate_card_catalog.js.
# Sem ela o rate limit inviabiliza baixar o catálogo completo.
# Grátis em: https://dev.pokemontcg.io/
VITE_POKEMON_API_KEY=

# Token da Apify, usado por scripts/update_liga_prices.js (scraping na nuvem).
# Opcional: só necessário se você usar o caminho Apify em vez do scraper local.
APIFY_TOKEN=
